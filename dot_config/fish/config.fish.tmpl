# Keep config.fish minimal; split startup config across conf.d/*.fish.
source ~/.config/fish/aliases.fish

# Dedupe PATH after all startup hooks have run.
set -l deduped_path
for path_entry in $PATH
    contains -- $path_entry $deduped_path; or set -a deduped_path $path_entry
end
set -gx PATH $deduped_path
